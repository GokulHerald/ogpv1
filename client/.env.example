# API base — must include /api/v1, or set only the origin and the client will append /api/v1
# VITE_API_URL=http://localhost:5001/api/v1

# Firebase Web (Phone OTP) — from Firebase Console → Project settings → Your apps → Web app config
# VITE_FIREBASE_API_KEY=...
# VITE_FIREBASE_AUTH_DOMAIN=...
# VITE_FIREBASE_PROJECT_ID=...
# VITE_FIREBASE_APP_ID=...
