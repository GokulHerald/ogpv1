# Copy to server/.env (local) or set in Vercel **server/API** project → Environment Variables

MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Payment gateways (sandbox)
ESEWA_MERCHANT_ID=EPAYTEST
# Epay-v2 test secret (quote if your shell/parser strips & or /)
ESEWA_SECRET="8gBm/:&EnhH.1/q"
ESEWA_PAYMENT_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_URL=https://rc.esewa.com.np/api/epay/transaction/status/

KHALTI_SECRET_KEY=

# === Required for payment redirects (SERVER project on Vercel) ===
# Live frontend — where users land after pay (React /payment/success)
CLIENT_URL=https://ogpv1.vercel.app
# Public API origin — Khalti/eSewa callbacks (no /api/v1 suffix)
SERVER_URL=https://your-api-deployment.vercel.app

# Local dev example:
# CLIENT_URL=http://localhost:5173
# SERVER_URL=http://localhost:5001
